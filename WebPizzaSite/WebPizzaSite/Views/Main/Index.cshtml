@model List<CategoryItemViewModel>
@{

}

<h1 class="text-center">Смачна піца для кожного</h1>
<div class="container">
    <a href="@Url.Action("Create")" class="btn btn-success">Додати</a>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Фото</th>
                <th scope="col">Назва</th>
                <th scope="col">Опис</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row">@item.Id</th>
                    <td><img src="@item.Image" alt="@item.Name" width="100" /></td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>
                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                    <td>
                        <i href="@Url.Action("Delete", new { id = item.Id })" class="bi bi-trash3 fs-3 text-danger"
                           data-delete
                           data-id="@item.Id"
                           data-name="@item.Name"
                           style="cursor: pointer"></i>
                    </td>
                </tr>
            }


        </tbody>
    </table>
</div>

@await Html.PartialAsync("Partials/_ModalDelete")


   
